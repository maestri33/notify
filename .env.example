# Internal connections only.
# All external credentials (SMTP, SMS Gateway, ElevenLabs) are configured
# via the dashboard at /config and stored in the ServiceConfig table.

# Database (SQLite inside the `app-data` named volume, mounted at /app/data)
DATABASE_URL=sqlite:////app/data/notify.db

# Redis (RQ broker)
REDIS_URL=redis://redis:6379/0

# Baileys sidecar (internal Docker network)
BAILEYS_URL=http://baileys:3000

# App
APP_ENV=development
LOG_LEVEL=INFO
