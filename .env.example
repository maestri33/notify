# Notify environment — copy to .env and edit as needed.
#
# Docker:  cp .env.example .env
# Native:  edit /etc/notify.env (created by install.sh)
#
# All external credentials (SMTP, SMS Gateway, ElevenLabs) are configured
# via the dashboard at /config and stored in the ServiceConfig table.

# ── Database ──────────────────────────────────────────────────────────────
# Docker:  SQLite inside the `app-data` named volume
# Native:  SQLite at /var/lib/notify/notify.db
DATABASE_URL=sqlite:////app/data/notify.db

# ── Redis ─────────────────────────────────────────────────────────────────
# Docker:  redis service name
# Native:  redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ── Baileys sidecar ───────────────────────────────────────────────────────
# Docker:  baileys service name on port 3000
# Native:  http://localhost:3000
BAILEYS_URL=http://baileys:3000

# Path to the shared Baileys SQLite database (contacts, messages, auth)
# Native:  /var/lib/notify/baileys.db
# Docker:  /app/data/baileys.db
BAILEYS_DB_PATH=/app/data/baileys.db

# ── App ───────────────────────────────────────────────────────────────────
# development | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── CLI ───────────────────────────────────────────────────────────────────
# Optional: set for the CLI so you don't need to export it every time.
# Native:  http://localhost:8000
# Remote:  http://<server-ip>:8000
# NOTIFY_URL=http://localhost:8000
