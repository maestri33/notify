# ============================================================================
# .env.example — copie pra .env e preencha
# ============================================================================
# Servico
SERVICE_NAME=notify
ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO
PORT=80
PUBLIC_BASE_URL=https://notify.v7m.live
DMZ_BASE_URL=http://notify.local:80

# Banco — cada servico tem o SEU proprio
# SQLite local (default, zero infra). Tortoise: 2 barras p/ relativo, 3 p/ absoluto.
DATABASE_URL=sqlite://data/app.db
# Quando crescer, troca pra Postgres dedicado deste servico:
# DATABASE_URL=postgres://user:pass@db.proxmox.local:5432/notify

# Redis (cache + pub/sub leve) — opcional, descomente quando for usar
# REDIS_URL=redis://redis.proxmox.local:6379/0

# RabbitMQ (mensageria entre microservices) — opcional, descomente quando for usar
# AMQP_URL=amqp://guest:guest@rabbit.proxmox.local:5672/

# SMTP API externa (mail merge)
SMTP_API_BASE_URL=http://mail.local
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# WhatsApp API (Evolution GO / whatsmeow)
WHATSAPP_API_BASE_URL=http://whats.local
WHATSAPP_GLOBAL_API_KEY=troque-isto
WHATSAPP_INSTANCE_NAME=default

# DeepSeek AI (geracao de titulos, edicao de templates, mensagens)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-pro
DEEPSEEK_DEFAULT_TEMPERATURE=0.3

# ElevenLabs TTS (text-to-speech)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Gemini (geracao de imagens)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_VISION_MODEL=gemini-3-flash-preview
