{
  "$comment": "Claude Code via DeepSeek (endpoint compatível Anthropic). Tokens reais idealmente exportados no shell — manter aqui apenas como fallback.",
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "sk-9960f608efe84ed48bd8cf0e797f9eec",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-pro",
    "CLAUDE_CODE_SUBAGENT_MODEL": "deepseek-v4-pro",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "API_TIMEOUT_MS": "3000000"
  },
  "permissions": {
    "allow": [
      "Bash(uv *)",
      "Bash(make *)",
      "Bash(pytest *)",
      "Bash(aerich *)",
      "Bash(curl http://localhost:80/*)",
      "Bash(curl http://127.0.0.1:80/*)",
      "Read(./**)",
      "Edit(./app/**)",
      "Edit(./tests/**)",
      "Edit(./.claude/memory/**)",
      "Write(./app/**)",
      "Write(./tests/**)",
      "Write(./.claude/memory/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Edit(./pyproject.toml)",
      "Edit(./.env)",
      "Edit(./.claude/CLAUDE.md)"
    ]
  }
}